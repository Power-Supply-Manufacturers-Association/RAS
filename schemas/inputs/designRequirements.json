{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/RAS/inputs/designRequirements.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "designRequirements",
    "description": "The list of requirements that a given resistor must comply with. Built on top of the PEAS designRequirementsBase mixin, with resistor-specific required specs (resistance + powerRating) and a narrowed role / allowedTechnologies / application / subApplication.",
    "allOf": [
        {
            "$ref": "../../../PEAS/schemas/utils.json#/$defs/designRequirementsBase"
        },
        {
            "type": "object",
            "properties": {
                "resistance": {
                    "description": "Required values for the resistance, in Ohm",
                    "$ref": "../../../PEAS/schemas/utils.json#/$defs/dimensionWithTolerance"
                },
                "powerRating": {
                    "description": "Required continuous power dissipation rating, in W (typically at the manufacturer-specified ambient or case temperature)",
                    "type": "number",
                    "minimum": 0
                },
                "maximumWorkingVoltage": {
                    "description": "Maximum DC working voltage allowed across the resistor, in V",
                    "type": "number",
                    "minimum": 0
                },
                "maximumOverloadVoltage": {
                    "description": "Maximum short-pulse / overload voltage, in V",
                    "type": "number",
                    "minimum": 0
                },
                "maximumTcr": {
                    "description": "Maximum temperature coefficient of resistance, in ppm/K",
                    "type": "number",
                    "minimum": 0
                },
                "maximumDriftLongTerm": {
                    "description": "Maximum allowed long-term resistance drift, in % over the operating life",
                    "type": "number",
                    "minimum": 0
                },
                "maximumNoise": {
                    "description": "Maximum allowed current-noise index, in dB or microvolts/V depending on the technology",
                    "type": "number"
                },
                "minimumPulseEnergy": {
                    "description": "Minimum pulse-energy withstand requirement, in J",
                    "type": "number",
                    "minimum": 0
                },
                "maximumEsl": {
                    "description": "Maximum equivalent series inductance, in H",
                    "type": "number",
                    "minimum": 0
                },
                "role": {
                    "description": "Resistor role in the converter. Used together with 'topology' to pick the correct stress and lifetime model.",
                    "type": "string",
                    "enum": [
                        "currentSense",
                        "gate",
                        "snubber",
                        "damping",
                        "bleed",
                        "preCharge",
                        "inrush",
                        "divider",
                        "feedback",
                        "termination",
                        "pullUp",
                        "pullDown",
                        "fusible"
                    ]
                },
                "allowedTechnologies": {
                    "description": "Subset of resistor technologies acceptable for this design. If absent, all technologies are allowed.",
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "thinFilm",
                            "thickFilm",
                            "metalFilm",
                            "metalOxide",
                            "wirewound",
                            "carbonComposition",
                            "carbonFilm",
                            "metalFoil",
                            "bulkMetalFoil",
                            "currentSenseShunt",
                            "melf"
                        ]
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "application": {
                    "$ref": "../../../PEAS/schemas/utils.json#/$defs/resistorApplication"
                },
                "subApplication": {
                    "$ref": "../../../PEAS/schemas/utils.json#/$defs/resistorSubApplication"
                }
            },
            "required": [
                "resistance",
                "powerRating"
            ]
        }
    ],
    "$defs": {}
}
