{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/ras/inputs/designRequirements.json",
    "$comment": "SPDX-License-Identifier: MIT",
    "title": "designRequirements",
    "description": "The list of requirements that an RAS component (resistor, varistor or thermistor) must comply with. Built on top of the PEAS designRequirementsBase mixin, with a deviceType discriminator that drives per-type required ratings — mirrors the SAS pattern.",
    "allOf": [
        {
            "$ref": "https://psma.com/peas/utils.json#/$defs/designRequirementsBase"
        },
        {
            "type": "object",
            "properties": {
                "deviceType": {
                    "description": "Required device type. Drives the per-type oneOf below and aligns with the RAS top-level field name.",
                    "type": "string",
                    "enum": [
                        "resistor",
                        "varistor",
                        "thermistor"
                    ]
                },
                "maximumWorkingVoltage": {
                    "description": "Maximum DC working voltage allowed across the component, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "maximumOverloadVoltage": {
                    "description": "Maximum short-pulse / overload voltage, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "application": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/resistorApplication"
                },
                "subApplication": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/resistorSubApplication"
                }
            },
            "required": [
                "deviceType"
            ],
            "oneOf": [
                {
                    "description": "Resistor-specific requirements",
                    "properties": {
                        "deviceType": {
                            "const": "resistor"
                        },
                        "resistance": {
                            "description": "Required values for the resistance, in Ohm.",
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        "powerRating": {
                            "description": "Required continuous power dissipation rating, in W.",
                            "type": "number",
                            "minimum": 0
                        },
                        "maximumTcr": {
                            "description": "Maximum temperature coefficient of resistance, in ppm/K.",
                            "type": "number",
                            "minimum": 0
                        },
                        "maximumDriftLongTerm": {
                            "description": "Maximum allowed long-term resistance drift, in % over the operating life.",
                            "type": "number",
                            "minimum": 0
                        },
                        "maximumNoise": {
                            "description": "Maximum allowed current-noise index, in dB.",
                            "type": "number"
                        },
                        "minimumPulseEnergy": {
                            "description": "Minimum pulse-energy withstand requirement, in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "maximumEsl": {
                            "description": "Maximum equivalent series inductance, in H.",
                            "type": "number",
                            "minimum": 0
                        },
                        "role": {
                            "description": "Resistor role in the converter.",
                            "type": "string",
                            "enum": [
                                "currentSense",
                                "gate",
                                "snubber",
                                "damping",
                                "bleed",
                                "preCharge",
                                "inrush",
                                "divider",
                                "feedback",
                                "termination",
                                "pullUp",
                                "pullDown",
                                "fusible"
                            ]
                        },
                        "allowedTechnologies": {
                            "description": "Subset of resistor technologies acceptable for this design. If absent, all technologies are allowed.",
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "thinFilm",
                                    "thickFilm",
                                    "metalFilm",
                                    "metalOxide",
                                    "wirewound",
                                    "carbonComposition",
                                    "carbonFilm",
                                    "metalFoil",
                                    "bulkMetalFoil",
                                    "currentSenseShunt",
                                    "melf"
                                ]
                            },
                            "minItems": 1,
                            "uniqueItems": true
                        }
                    },
                    "required": [
                        "resistance"
                    ]
                },
                {
                    "description": "Varistor-specific requirements",
                    "properties": {
                        "deviceType": {
                            "const": "varistor"
                        },
                        "ratedContinuousVoltage": {
                            "description": "Required minimum continuous working voltage rating (V_M), in V.",
                            "type": "number",
                            "minimum": 0
                        },
                        "voltageType": {
                            "description": "Whether the continuous rating is AC RMS or DC.",
                            "type": "string",
                            "enum": [
                                "ac",
                                "dc"
                            ]
                        },
                        "maximumClampingVoltage": {
                            "description": "Maximum allowed clamping voltage at the rated surge current, in V.",
                            "type": "number",
                            "minimum": 0
                        },
                        "minimumPeakSurgeCurrent": {
                            "description": "Required minimum peak surge current capability for the rated waveform, in A.",
                            "type": "number",
                            "minimum": 0
                        },
                        "minimumEnergyAbsorption": {
                            "description": "Required minimum single-pulse energy absorption capability, in J.",
                            "type": "number",
                            "minimum": 0
                        },
                        "maximumCapacitance": {
                            "description": "Maximum allowed capacitance, in F (lower = better for high-frequency lines).",
                            "type": "number",
                            "minimum": 0
                        },
                        "role": {
                            "description": "Varistor role in the converter.",
                            "type": "string",
                            "enum": [
                                "surgeProtection",
                                "esdProtection",
                                "snubber",
                                "voltageClamp"
                            ]
                        },
                        "allowedTechnologies": {
                            "description": "Subset of varistor technologies acceptable for this design.",
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "metalOxide",
                                    "siliconCarbide",
                                    "multiLayer",
                                    "polymer"
                                ]
                            },
                            "minItems": 1,
                            "uniqueItems": true
                        }
                    },
                    "required": [
                        "ratedContinuousVoltage"
                    ],
                    "anyOf": [
                        {
                            "required": [
                                "minimumEnergyAbsorption"
                            ]
                        },
                        {
                            "required": [
                                "minimumPeakSurgeCurrent"
                            ]
                        }
                    ],
                    "$comment": "At least one energy-class rating is required: minimumEnergyAbsorption (Joule-rated disc varistors) or minimumPeakSurgeCurrent (multilayer/ESD varistors that publish no Joule rating)."
                },
                {
                    "description": "Thermistor-specific requirements",
                    "properties": {
                        "deviceType": {
                            "const": "thermistor"
                        },
                        "resistanceAt25C": {
                            "description": "Required zero-power resistance R25 at 25 °C, in Ohm.",
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        "bConstant": {
                            "description": "Required B (beta) constant, in K (NTC parts).",
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        "minimumSteadyStateCurrent": {
                            "description": "Required minimum continuous (steady-state) current capability, in A (inrush limiters).",
                            "type": "number",
                            "minimum": 0
                        },
                        "minimumEnergy": {
                            "description": "Required minimum single-event energy absorption capability (capacitive load), in J (inrush limiters).",
                            "type": "number",
                            "minimum": 0
                        },
                        "switchTemperature": {
                            "description": "Required PTC switch / reference temperature, in Celsius.",
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        "role": {
                            "description": "Thermistor role in the converter.",
                            "type": "string",
                            "enum": [
                                "inrushLimiting",
                                "temperatureSensing",
                                "temperatureCompensation",
                                "overtemperatureProtection"
                            ]
                        },
                        "allowedTechnologies": {
                            "description": "Subset of thermistor technologies acceptable for this design. If absent, all technologies are allowed.",
                            "type": "array",
                            "items": {
                                "$ref": "https://psma.com/ras/thermistor.json#/$defs/technology"
                            },
                            "minItems": 1,
                            "uniqueItems": true
                        }
                    },
                    "required": [
                        "resistanceAt25C"
                    ]
                }
            ]
        }
    ],
    "$defs": {},
    "unevaluatedProperties": false
}
