{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/RAS/RAS.json",
    "title": "RAS",
    "description": "Resistor-family Agnostic Structure (RAS). A document carries inputs, exactly one of {resistor, varistor} (the field name is the discriminator), and outputs.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "inputs": {
            "description": "Design requirements and operating points for this component",
            "title": "inputs",
            "$ref": "./inputs.json"
        },
        "resistor": {
            "description": "Fixed resistor",
            "title": "resistor",
            "$ref": "./resistor.json"
        },
        "varistor": {
            "description": "Varistor / MOV",
            "title": "varistor",
            "$ref": "./varistor.json"
        },
        "outputs": {
            "description": "Computed results per operating point. outputs[i] aligns positionally with inputs.operatingPoints[i].",
            "title": "outputs",
            "type": "array",
            "items": {
                "$ref": "./outputs.json"
            }
        }
    },
    "required": [
        "inputs",
        "outputs"
    ],
    "oneOf": [
        {
            "required": [
                "resistor"
            ]
        },
        {
            "required": [
                "varistor"
            ]
        }
    ]
}
