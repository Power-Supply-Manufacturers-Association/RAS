{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/ras/varistor.json",
    "title": "varistor",
    "description": "Varistor / MOV (Metal Oxide Varistor) component data. The presence of the 'varistor' field at the top level of an RAS document discriminates the device type — there is no deviceType property.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "title": "varistorManufacturerInfo",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/name"
                },
                "reference": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/reference"
                },
                "status": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/status"
                },
                "description": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/description"
                },
                "orderCode": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/orderCode"
                },
                "datasheetUrl": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/datasheetUrl"
                },
                "spiceModel": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/spiceModel"
                },
                "family": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/family"
                },
                "datasheetInfo": {
                    "$ref": "#/$defs/datasheetInfo"
                }
            },
            "required": [
                "name",
                "datasheetInfo"
            ]
        },
        "distributorsInfo": {
            "description": "Where to buy this component",
            "type": "array",
            "items": {
                "$ref": "https://psma.com/peas/utils.json#/$defs/distributorInfo"
            }
        }
    },
    "required": [
        "manufacturerInfo"
    ],
    "$defs": {
        "datasheetInfo": {
            "title": "varistorDatasheetInfo",
            "description": "All information extracted from the varistor datasheet.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "part": {
                    "$ref": "#/$defs/part"
                },
                "electrical": {
                    "$ref": "#/$defs/electrical"
                },
                "thermal": {
                    "$ref": "./utils.json#/$defs/thermal"
                },
                "mechanical": {
                    "$ref": "./utils.json#/$defs/mechanical"
                },
                "viCurve": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/curve",
                    "description": "Voltage vs current characteristic in the conduction region."
                }
            },
            "required": [
                "part",
                "electrical"
            ]
        },
        "part": {
            "title": "varistorPart",
            "description": "Basic varistor part identification.",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/datasheetInfoPartBase"
                },
                {
                    "type": "object",
                    "properties": {
                        "partNumber": {},
                        "series": {},
                        "case": {},
                        "description": {},
                        "technology": {
                            "type": "string",
                            "enum": [
                                "metalOxide",
                                "siliconCarbide",
                                "multiLayer",
                                "polymer"
                            ]
                        },
                        "matchcodeDescription": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "technology"
                    ]
                }
            ]
        },
        "electrical": {
            "title": "varistorElectrical",
            "description": "Varistor electrical characteristics — every field is relevant to varistors / MOVs.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "varistorVoltage": {
                    "description": "Varistor voltage V_1mA at the 1 mA reference current, in V.",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                },
                "maxContinuousAcVoltage": {
                    "description": "Maximum continuous AC working voltage (V_RMS), in V.",
                    "type": "number",
                    "minimum": 0
                },
                "maxContinuousDcVoltage": {
                    "description": "Maximum continuous DC working voltage, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "clampingVoltage": {
                    "description": "Clamping voltage V_C at the rated peak surge current I_PP, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "clampingCurrent": {
                    "description": "Test current at which the clamping voltage is specified, in A.",
                    "type": "number",
                    "minimum": 0
                },
                "peakSurgeCurrent": {
                    "description": "Peak surge current I_PP for the rated waveform (e.g. 8/20 µs), in A.",
                    "type": "number",
                    "minimum": 0
                },
                "surgeWaveform": {
                    "description": "Waveform of the rated surge in 'rise/decay' microseconds (e.g. '8/20').",
                    "type": "string"
                },
                "energyAbsorption": {
                    "description": "Maximum single-pulse energy absorption capability for a 10/1000 µs waveform, in J. Optional: this is a power-/disc-MOV rating used to size devices against AC-line surge energy. Multilayer chip varistors for circuit/ESD protection (e.g. TDK AVR series) are specified instead by peakSurgeCurrent at an 8/20 µs waveform and clampingVoltage, and typically publish no Joule rating — for those parts this field is absent.",
                    "type": "number",
                    "minimum": 0
                },
                "capacitance": {
                    "description": "Typical capacitance at 1 kHz, in F.",
                    "type": "number",
                    "minimum": 0
                },
                "leakageCurrent": {
                    "description": "DC leakage current at the maximum continuous voltage, in A.",
                    "type": "number",
                    "minimum": 0
                },
                "nonlinearityCoefficient": {
                    "description": "Non-linearity exponent α (V = k * I^(1/α)) in the varistor's conduction region.",
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            },
            "required": [
                "varistorVoltage",
                "clampingVoltage",
                "peakSurgeCurrent"
            ]
        }
    }
}
