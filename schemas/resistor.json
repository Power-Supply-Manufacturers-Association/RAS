{
    "description": "The description of a resistor",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/RAS/resistor.json",
    "title": "resistor",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "$ref": "#/$defs/manufacturerInfo"
        },
        "resistor": {
            "description": "Resistor data wrapper (used by some DB entries)",
            "type": "object"
        }
    },
    "required": [],
    "$defs": {
        "manufacturerInfo": {
            "description": "Container for manufacturer-specific information about the resistor \u2014 extends PEAS base with resistor-specific datasheetInfo.",
            "allOf": [
                {
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/manufacturerInfo"
                },
                {
                    "type": "object",
                    "properties": {
                        "datasheetInfo": {
                            "description": "Information extracted from the component datasheet",
                            "$ref": "#/$defs/datasheetInfo"
                        }
                    },
                    "required": [
                        "datasheetInfo"
                    ]
                }
            ]
        },
        "datasheetInfo": {
            "description": "Information extracted from the component datasheet",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "part": {
                    "description": "Basic part identification",
                    "$ref": "#/$defs/part"
                },
                "electrical": {
                    "description": "Electrical characteristics",
                    "$ref": "#/$defs/electrical"
                },
                "thermal": {
                    "description": "Thermal characteristics",
                    "$ref": "#/$defs/thermal"
                },
                "mechanical": {
                    "description": "Mechanical dimensions and shape information",
                    "$ref": "#/$defs/mechanical"
                },
                "business": {
                    "description": "Commercial and business information",
                    "$ref": "#/$defs/business"
                },
                "modelParams": {
                    "description": "SPICE model parameters",
                    "$ref": "#/$defs/modelParams"
                },
                "factors": {
                    "description": "Derating factors for temperature",
                    "$ref": "#/$defs/factors"
                }
            },
            "required": [
                "part",
                "electrical",
                "mechanical"
            ]
        },
        "part": {
            "description": "Basic part identification",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "partNumber": {
                    "description": "Manufacturer part number",
                    "type": [
                        "string"
                    ]
                },
                "series": {
                    "description": "Product series name",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "technology": {
                    "description": "Resistor technology type",
                    "type": [
                        "string"
                    ],
                    "enum": [
                        "thinFilm",
                        "thickFilm",
                        "wirewound",
                        "carbonComposition",
                        "metalOxide",
                        "foil",
                        "shunt"
                    ]
                },
                "case": {
                    "description": "Case or package code",
                    "type": [
                        "string"
                    ]
                },
                "matchcodeDescription": {
                    "description": "Human-readable description of the part",
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "partNumber",
                "technology",
                "case"
            ]
        },
        "electrical": {
            "description": "Electrical characteristics",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "resistance": {
                    "description": "Nominal resistance in Ohms",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "tolerance": {
                    "description": "Resistance tolerance as fraction (0.01 = 1%)",
                    "type": [
                        "number"
                    ]
                },
                "temperatureCoefficient": {
                    "description": "Temperature coefficient of resistance in ppm/K",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "powerRating": {
                    "description": "Maximum power rating in Watts at reference temperature",
                    "type": [
                        "number"
                    ]
                },
                "powerRatingTemperature": {
                    "description": "Reference temperature for power rating in Celsius",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "maxVoltage": {
                    "description": "Maximum working voltage in Volts",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "maxOverloadVoltage": {
                    "description": "Maximum overload voltage in Volts",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "insulationResistance": {
                    "description": "Insulation resistance in Ohms",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "noiseIndex": {
                    "description": "Current noise index in dB",
                    "type": [
                        "number",
                        "null"
                    ]
                }
            },
            "required": [
                "resistance",
                "tolerance",
                "powerRating"
            ]
        },
        "thermal": {
            "description": "Thermal characteristics",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "operatingTemperature": {
                    "description": "Operating temperature range in Celsius",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                }
            },
            "required": []
        },
        "dimensions": {
            "description": "Physical dimensions of the component",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "width": {
                    "description": "Width in meters",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "length": {
                    "description": "Length in meters",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                },
                "height": {
                    "description": "Height in meters",
                    "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                }
            },
            "required": []
        },
        "shape": {
            "description": "Component shape and assembly information",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "assembly": {
                    "description": "Assembly type",
                    "$ref": "./utils.json#/$defs/connectionType"
                },
                "required": []
            },
            "mechanical": {
                "description": "Mechanical dimensions and shape information",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "dimensions": {
                        "description": "Physical dimensions",
                        "$ref": "#/$defs/dimensions"
                    },
                    "shape": {
                        "description": "Shape and assembly",
                        "$ref": "#/$defs/shape"
                    }
                },
                "required": [
                    "shape"
                ]
            },
            "dimensions": {
                "description": "Physical dimensions of the component",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "width": {
                        "description": "Width in meters",
                        "anyOf": [
                            {
                                "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "length": {
                        "description": "Length in meters",
                        "anyOf": [
                            {
                                "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "height": {
                        "description": "Height in meters",
                        "anyOf": [
                            {
                                "$ref": "./utils.json#/$defs/dimensionWithTolerance"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    }
                },
                "required": []
            },
            "shape": {
                "description": "Component shape and assembly information",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "assembly": {
                        "description": "Assembly type",
                        "type": [
                            "string"
                        ],
                        "enum": [
                            "SMT",
                            "THT",
                            "Chassis"
                        ]
                    },
                    "shapeType": {
                        "description": "Package shape type",
                        "type": [
                            "string"
                        ]
                    }
                },
                "required": [
                    "assembly",
                    "shapeType"
                ]
            },
            "business": {
                "description": "Commercial and supply chain information",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "packaging": {
                        "description": "Packaging format",
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "vpe": {
                        "description": "Units per package/reel",
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "moq": {
                        "description": "Minimum order quantity",
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "priceCost": {
                        "description": "Cost price",
                        "type": [
                            "number",
                            "null"
                        ]
                    }
                },
                "required": []
            },
            "modelParams": {
                "description": "SPICE model parameters for circuit simulation",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "r": {
                        "description": "Resistance in Ohms",
                        "type": [
                            "number",
                            "null"
                        ]
                    },
                    "tcr1": {
                        "description": "First-order temperature coefficient in 1/K",
                        "type": [
                            "number",
                            "null"
                        ]
                    },
                    "tcr2": {
                        "description": "Second-order temperature coefficient in 1/K^2",
                        "type": [
                            "number",
                            "null"
                        ]
                    }
                },
                "required": []
            },
            "factors": {
                "description": "Derating factors as functions of temperature",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "powerDeratingTemperature": {
                        "description": "Temperature values for power derating curve in Celsius",
                        "$ref": "./utils.json#/$defs/numberArray"
                    },
                    "powerDeratingAmplitude": {
                        "description": "Power derating factors (fraction of rated power) at specified temperatures",
                        "$ref": "./utils.json#/$defs/numberArray"
                    }
                },
                "required": []
            }
        }
    }
}