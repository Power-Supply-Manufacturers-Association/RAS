{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/ras/resistor.json",
    "title": "resistor",
    "description": "Resistor component data. The presence of the 'resistor' field at the top level of an RAS document discriminates the device type — there is no deviceType property.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "description": "Manufacturer-specific information — extends PEAS manufacturerInfo with resistor-specific datasheetInfo.",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo"
                },
                {
                    "type": "object",
                    "properties": {
                        "datasheetInfo": {
                            "$ref": "#/$defs/datasheetInfo"
                        }
                    },
                    "required": [
                        "datasheetInfo"
                    ]
                }
            ]
        },
        "distributorsInfo": {
            "description": "Where to buy this component",
            "type": "array",
            "items": {
                "$ref": "https://psma.com/peas/utils.json#/$defs/distributorInfo"
            }
        }
    },
    "required": [
        "manufacturerInfo"
    ],
    "$defs": {
        "datasheetInfo": {
            "description": "All information extracted from the resistor datasheet.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "part": {
                    "$ref": "#/$defs/part"
                },
                "electrical": {
                    "$ref": "#/$defs/electrical"
                },
                "thermal": {
                    "$ref": "./utils.json#/$defs/thermal"
                },
                "mechanical": {
                    "$ref": "./utils.json#/$defs/mechanical"
                },
                "business": {
                    "$ref": "./utils.json#/$defs/business"
                },
                "modelParams": {
                    "$ref": "#/$defs/modelParams"
                },
                "factors": {
                    "$ref": "#/$defs/factors"
                }
            },
            "required": [
                "part",
                "electrical"
            ]
        },
        "part": {
            "description": "Basic resistor part identification.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "partNumber": {
                    "type": "string"
                },
                "series": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "technology": {
                    "type": "string",
                    "enum": [
                        "thinFilm",
                        "thickFilm",
                        "metalFilm",
                        "metalOxide",
                        "wirewound",
                        "carbonComposition",
                        "carbonFilm",
                        "metalFoil",
                        "bulkMetalFoil",
                        "currentSenseShunt",
                        "melf"
                    ]
                },
                "case": {
                    "type": "string",
                    "description": "Package code (0603, 2512, etc.)"
                },
                "matchcodeDescription": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "partNumber",
                "technology",
                "case"
            ]
        },
        "electrical": {
            "description": "Resistor electrical characteristics.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "resistance": {
                    "description": "Nominal resistance, in Ohms.",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                },
                "tolerance": {
                    "description": "Resistance tolerance as a fraction (0.01 = 1%).",
                    "type": "number",
                    "minimum": 0
                },
                "temperatureCoefficient": {
                    "description": "Temperature coefficient of resistance, in ppm/K.",
                    "type": "number"
                },
                "powerRating": {
                    "description": "Maximum power rating at the reference temperature, in W.",
                    "type": "number",
                    "minimum": 0
                },
                "powerRatingTemperature": {
                    "description": "Reference temperature for the power rating, in Celsius.",
                    "type": "number"
                },
                "maxVoltage": {
                    "description": "Maximum continuous working voltage, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "maxOverloadVoltage": {
                    "description": "Maximum short-pulse / overload voltage, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "insulationResistance": {
                    "description": "Insulation resistance, in Ohms.",
                    "type": "number",
                    "minimum": 0
                },
                "noiseIndex": {
                    "description": "Current noise index, in dB.",
                    "type": "number"
                }
            },
            "required": [
                "resistance",
                "tolerance",
                "powerRating"
            ]
        },
        "modelParams": {
            "description": "SPICE model parameters for resistor.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "r": {
                    "description": "Resistance, in Ohms.",
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "tcr1": {
                    "description": "First-order TCR, in 1/K.",
                    "type": "number"
                },
                "tcr2": {
                    "description": "Second-order TCR, in 1/K^2.",
                    "type": "number"
                }
            }
        },
        "factors": {
            "description": "Derating factors as functions of temperature.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "powerDerating": {
                    "description": "Power derating curve.",
                    "$ref": "./utils.json#/$defs/deratingCurve"
                }
            }
        }
    }
}
