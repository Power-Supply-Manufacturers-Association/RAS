{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/ras/utils.json",
    "title": "RAS utils",
    "description": "Shared sub-schemas reused by every RAS per-type document (resistor, varistor, thermistor). The `part` block is per-type (technology enums differ) — thermal, mechanical and deratingCurve are shared here.",
    "$defs": {
        "thermal": {
            "title": "rasThermal",
            "description": "Thermal characteristics — extends PEAS datasheetInfoThermal with body-to-ambient thermal resistance.",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/datasheetInfoThermal"
                },
                {
                    "type": "object",
                    "properties": {
                        "operatingTemperature": {},
                        "thermalResistance": {
                            "description": "Thermal resistance from body to ambient, in K/W.",
                            "type": "number",
                            "minimum": 0
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "mechanical": {
            "title": "rasMechanical",
            "description": "Mechanical specs — extends PEAS datasheetInfoMechanical with a package case field.",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/datasheetInfoMechanical"
                },
                {
                    "type": "object",
                    "properties": {
                        "length": {},
                        "width": {},
                        "height": {},
                        "diameter": {},
                        "weight": {},
                        "shapeType": {},
                        "assemblyType": {},
                        "case": {
                            "type": "string",
                            "description": "Package code (e.g. 0603, 2512, axial)."
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "deratingCurve": {
            "title": "deratingCurve",
            "description": "Power / current / voltage derating curve as paired arrays. Index-aligned: amplitude[i] is the rated fraction at temperature[i].",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "temperature": {
                    "description": "Temperature breakpoints, in Celsius.",
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "minItems": 2
                },
                "amplitude": {
                    "description": "Derating fraction (0..1) at each temperature breakpoint.",
                    "type": "array",
                    "items": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    },
                    "minItems": 2
                }
            },
            "required": [
                "temperature",
                "amplitude"
            ]
        }
    }
}
