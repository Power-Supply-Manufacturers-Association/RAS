{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/RAS/utils.json",
    "title": "RAS utils",
    "description": "Shared sub-schemas reused by every RAS per-type document (resistor, varistor). The `part` block is intentionally per-type because the technology enum differs (resistor vs MOV) — only thermal, mechanical and business are reused.",
    "$defs": {
        "thermal": {
            "description": "Thermal characteristics — shared across all RAS device types.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "operatingTemperature": {
                    "description": "Operating temperature range, in Celsius.",
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/dimensionWithTolerance"
                },
                "thermalResistance": {
                    "description": "Thermal resistance from body to ambient, in K/W.",
                    "type": "number",
                    "minimum": 0
                }
            }
        },
        "mechanical": {
            "description": "Mechanical specs — shared across all RAS device types.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "assemblyType": {
                    "description": "PCB mounting / assembly type.",
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/connectionType"
                },
                "case": {
                    "type": "string",
                    "description": "Package code (e.g. 0603, 2512, axial)."
                },
                "shapeType": {
                    "type": "string",
                    "description": "Free-form package shape descriptor (e.g. 'SMD chip', 'axial', 'disc')."
                },
                "length": {
                    "description": "Body length in metres.",
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/dimensionWithTolerance"
                },
                "width": {
                    "description": "Body width in metres.",
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/dimensionWithTolerance"
                },
                "height": {
                    "description": "Body height in metres.",
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/dimensionWithTolerance"
                },
                "diameter": {
                    "description": "Body diameter in metres (for cylindrical or disc-shaped parts).",
                    "$ref": "http://openconverters.com/schemas/PEAS/utils.json#/$defs/dimensionWithTolerance"
                },
                "weight": {
                    "type": "number",
                    "description": "kg"
                }
            }
        },
        "business": {
            "description": "Commercial info — shared across all RAS device types.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "packaging": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "vpe": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Units per package"
                },
                "moq": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Minimum order quantity"
                },
                "leadTime": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "weeks"
                },
                "stock": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "cost": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "unit cost"
                }
            }
        },
        "deratingCurve": {
            "description": "Power / current / voltage derating curve as paired arrays. Index-aligned: amplitude[i] is the rated fraction at temperature[i].",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "temperature": {
                    "description": "Temperature breakpoints, in Celsius.",
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "minItems": 2
                },
                "amplitude": {
                    "description": "Derating fraction (0..1) at each temperature breakpoint.",
                    "type": "array",
                    "items": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    },
                    "minItems": 2
                }
            },
            "required": [
                "temperature",
                "amplitude"
            ]
        }
    }
}
