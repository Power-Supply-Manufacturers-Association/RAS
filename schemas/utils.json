{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/RAS/utils.json",
    "title": "utils",
    "description": "Shared definition utilities for RAS (Resistor Agnostic Structure)",
    "type": "object",
    "properties": {
        "dimensionWithTolerance": {
            "$ref": "#/$defs/dimensionWithTolerance"
        },
        "curve": {
            "$ref": "#/$defs/curve"
        },
        "numberArray": {
            "$ref": "#/$defs/numberArray"
        }
    },
    "$defs": {
        "dimensionWithTolerance": {
            "description": "A dimension with minimum, nominal, and maximum values",
            "type": "object",
            "properties": {
                "minimum": {
                    "description": "The minimum value of the dimension",
                    "type": "number"
                },
                "nominal": {
                    "description": "The nominal value of the dimension",
                    "type": "number"
                },
                "maximum": {
                    "description": "The maximum value of the dimension",
                    "type": "number"
                }
            },
            "anyOf": [
                {"required": ["minimum"]},
                {"required": ["nominal"]},
                {"required": ["maximum"]}
            ]
        },
        "curve": {
            "type": "object",
            "description": "X-Y curve data points",
            "additionalProperties": false,
            "properties": {
                "xData": {
                    "description": "X-axis values",
                    "$ref": "#/$defs/numberArray"
                },
                "yData": {
                    "description": "Y-axis values",
                    "$ref": "#/$defs/numberArray"
                }
            }
        },
        "numberArray": {
            "type": "array",
            "description": "Array of numeric values",
            "items": {
                "type": ["number"]
            }
        },
        "distributorInfo": {
            "description": "Where to buy this component",
            "type": "object",
            "properties": {
                "name": { "type": "string", "description": "Distributor name" },
                "reference": { "type": ["string", "null"], "description": "Distributor part number" },
                "link": { "type": ["string", "null"], "format": "uri" },
                "cost": { "type": ["number", "null"], "description": "Unit cost in USD" },
                "stock": { "type": ["integer", "null"] },
                "country": { "type": ["string", "null"] }
            },
            "required": ["name"]
        },
        "substituteInfo": {
            "description": "A substitute or equivalent component",
            "type": "object",
            "properties": {
                "partNumber": { "type": "string", "description": "Part number of the substitute" },
                "manufacturer": { "type": ["string", "null"] },
                "type": { "type": "string", "enum": ["drop-in", "near-equivalent", "functional", "upgrade", "downgrade", "successor"] },
                "notes": { "type": ["string", "null"], "description": "Differences or caveats" },
                "source": { "type": ["string", "null"], "enum": ["manufacturer", "distributor", "cross-reference", "engineering", null] }
            },
            "required": ["partNumber"]
        }
    }
}
